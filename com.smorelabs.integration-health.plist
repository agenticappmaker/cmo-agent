<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.smorelabs.integration-health</string>

    <!-- Daily 7am ET (after the 8am triage but before the daily debrief).
         If a key is rotated or expired, ops sees it within a day. -->
    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>7</integer>
        <key>Minute</key>
        <integer>0</integer>
    </dict>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>-lc</string>
        <string>cd /Users/claudecode/cmo-agent &amp;&amp; /Users/claudecode/spirit_venv/bin/python integration_health.py --email</string>
    </array>

    <key>StandardOutPath</key>
    <string>/Users/claudecode/cmo-agent/logs/integration_health.out.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/claudecode/cmo-agent/logs/integration_health.err.log</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
    </dict>
</dict>
</plist>
